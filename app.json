{
  "expo": {
    "name": "PastureScan",
    "slug": "pasturescan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.pasturescan"
    },
    "android": {
      "package": "com.yourcompany.pasturescan",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "build": {
        "output": "static"
      },
      "name": "PastureScan",
      "shortName": "PastureScan",
      "description": "Scan and analyze pastures"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "apiBaseUrl": "https://image-2-biomass.vercel.app/api/v1",
      "router": {
        "origin": false
      }
    },
    "scheme": "pasturescan"
  }
}
