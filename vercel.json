{
  "version": 2,
  "builds": [
    {
      "src": "backend-services/api_gateway/app/main.py",
      "use": "@vercel/python",
      "config": {
        "handler": "main.py",
        "runtime": "python3.9"
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend-services/api_gateway/app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "build/$1"
    }
  ]
}
