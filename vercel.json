{
  "version": 2,
  "builds": [
    {
      "src": "front-end/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "front-end/build"
      }
    },
    {
      "src": "backend-services/api_gateway/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend-services/api_gateway/app/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/front-end/build/$1"
    }
  ]
}
